# =============================================================
# Pipeline UDA — Variáveis de Ambiente
# =============================================================
# Copie este arquivo para .env e preencha os valores:
#   cp .env.example .env
# =============================================================

# Chave de API do Google Gemini
# Obtenha em: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=sua-chave-aqui

# URL do banco de dados (padrão: SQLite local)
DATABASE_URL=sqlite:///./pipeline_uda.db

# Intervalo do scheduler em segundos (padrão: 86400 = 1 dia)
SCHEDULER_INTERVAL_SECONDS=86400

# Pasta de monitoramento de PDFs
DOWNLOADS_DIR=app/downloads
